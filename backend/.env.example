# FastAPI App Settings
PROJECT_NAME="AI Career Coach Backend"
API_V1_STR="/api/v1"

# CORS configuration (origins allowed to make request separated by commas)
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Database PostgreSQL settings
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres_secret_password"
POSTGRES_DB="ai_career_coach"

# Security Settings (Secret Key used to sign JWT tokens)
SECRET_KEY="YOUR_GENERATED_32_BYTES_RANDOM_SECRET_KEY_FOR_JWT_SECURITY_ENCRYPTION"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 Days

# Third Party Integrations
GEMINI_API_KEY="YOUR_GOOGLE_GEMINI_DEVELOPER_API_KEY"
